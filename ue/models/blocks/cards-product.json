{
  "definitions": [
    {
      "title": "Cards Product",
      "id": "cards-product",
      "model": "cards-product",
      "filter": "cards-product",
      "plugins": {
        "da": {
          "rows": 1,
          "columns": 2
        }
      }
    },
    {
      "title": "Cards Product Card",
      "id": "cards-product-card",
      "model": "cards-product-card",
      "plugins": {
        "da": {
          "rows": 1,
          "columns": 2,
          "fields": [
            { "name": "image", "selector": "div:nth-child(1)>picture>img[src]" },
            { "name": "imageAlt", "selector": "div:nth-child(1)>picture>img[alt]" },
            { "name": "text", "selector": "div:nth-child(2)" }
          ]
        }
      }
    }
  ],
  "models": [
    {
      "id": "cards-product-card",
      "fields": [
        {
          "component": "reference",
          "valueType": "string",
          "name": "image",
          "label": "Product Image",
          "multi": false
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "imageAlt",
          "label": "Image Alt Text",
          "value": ""
        },
        {
          "component": "richtext",
          "name": "text",
          "valueType": "string",
          "value": "",
          "label": "Content (collection name, product name, details)"
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "cards-product",
      "components": ["cards-product-card"]
    }
  ]
}
