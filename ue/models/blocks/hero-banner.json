{
  "definitions": [
    {
      "title": "Hero Banner",
      "id": "hero-banner",
      "model": "hero-banner",
      "plugins": {
        "da": {
          "unsafeHTML": "<div class=\"hero-banner\"><div><div><picture><source type=\"image/webp\" srcset=\"\"><source type=\"image/jpeg\" srcset=\"\"><img loading=\"eager\"></picture></div></div><div><div><p>Label</p><h1>Heading</h1><p>Short supporting paragraph.</p><p><a class=\"button\" href=\"#\">Call to action</a></p></div></div></div>",
          "fields": [
            { "name": "image", "selector": "div:first-child>div>picture>img[src]" },
            { "name": "imageAlt", "selector": "div:first-child>div>picture>img[alt]" },
            { "name": "video", "selector": "div:first-child>div>p>a[href]" },
            { "name": "videoText", "selector": "div:first-child>div>p>a" },
            { "name": "text", "selector": "div:last-child>div" }
          ]
        }
      }
    }
  ],
